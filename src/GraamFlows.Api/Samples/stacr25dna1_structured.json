  "_extractionGuide_waterfall": {
    "section": "Description of the Notes - Allocation of Senior Reduction Amount / Allocation of Subordinate Reduction Amount",
    "searchTerms": [
      "Senior Reduction Amount",
      "Subordinate Reduction Amount",
      "Supplemental Reduction Amount",
      "first,",
      "second,",
      "third,",
      "pro rata"
    ],
    "sampleLanguage": "Allocation of Senior Reduction Amount: On each Payment Date prior to the Maturity Date... first, if and only if the Class A-1 Cumulative Net Loss Test is satisfied for such Payment Date, an amount up to the Class A-1 Reduction Amount to the Class A-1 and Class A-1H Reference Tranches, pro rata based on their Class Notional Amounts immediately prior to such Payment Date; second, to the Class A-H Reference Tranche; third, to the Class A-1 and Class A-1H Reference Tranches, pro rata... Allocation of Subordinate Reduction Amount: first, to the Class M-1 and Class M-1H Reference Tranches, pro rata; second, to the Class M-2A and Class M-2AH Reference Tranches, pro rata...",
    "extractionRules": [
      "STACR waterfalls use SHIFTI (Shifting Interest) - seniors get reduced percentage of prepays",
      "CSCAP (Supplemental Subordinate Reduction Cap) limits how much can go to subordinates",
      "Look for numbered priority lists (first, second, third...) to determine payment order",
      "PRORATA when classes share subordination (e.g., 'M-1 and M-1H Reference Tranches, pro rata')",
      "SINGLE when class paid alone (e.g., 'to the Class A-H Reference Tranche')",
      "SEQ (Sequential) for ordered payment priority",
