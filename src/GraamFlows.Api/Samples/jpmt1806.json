  "payRules": [
    {
      "ruleName": "ScheProRata_G1",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('CredSuppDepletion')) SET_SCHED_STRUCT( PRORATA( PRORATA( SEQ('1A4,1A5,1A8,1A9'), PRORATA('1A10')), PRORATA('SUB' )))",
      "priority": 0
    },
    {
      "ruleName": "PpayShifti_G1",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('CredSuppDepletion')) SET_PREPAY_STRUCT( SHIFTI('ShiftPct', SHIFTI('ShiftPctNAS', SEQ('1A4,1A5,1A8,1A9'), PRORATA('1A10')), PRORATA('SUB' )))",
      "priority": 1
    },
    {
      "ruleName": "RecovShifti_G1",
