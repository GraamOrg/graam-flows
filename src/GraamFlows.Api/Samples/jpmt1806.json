      "formula": "if (FAILED('CredSuppDepletion')) SET_RECOV_STRUCT( SHIFTI('RecovShiftPct', PRORATA( PRORATA('1A4,1A5,1A8,1A9'), PRORATA('1A10')), PRORATA('SUB' )))",
      "priority": 8
    },
    {
      "ruleName": "LockoutRuleB1",
      "classGroupName": "B1",
      "formula": "if(BEGIN_BALANCE('B1,B2,B3,B4,B5,B6') / bal_at_issuance < VAR('SubLockoutPct') && BALANCE('SSUP') > 0) LOCKOUT()",
      "priority": 9
    },
    {
      "ruleName": "LockoutRuleB2",
      "classGroupName": "B2",
      "formula": "if(BEGIN_BALANCE('B2,B3,B4,B5,B6') / bal_at_issuance < VAR('SubLockoutPct') && BALANCE('B1') > 0) LOCKOUT()",
      "priority": 10
    },
    {
      "ruleName": "LockoutRuleB3",
      "classGroupName": "B3",
      "formula": "if(BEGIN_BALANCE('B3,B4,B5,B6') / bal_at_issuance < VAR('SubLockoutPct') && BALANCE('B2') > 0) LOCKOUT()",
      "priority": 11
    },
    {
      "ruleName": "LockoutRuleB4",
      "classGroupName": "B4",
      "formula": "if(BEGIN_BALANCE('B4,B5,B6') / bal_at_issuance < VAR('SubLockoutPct') && BALANCE('B3') > 0) LOCKOUT()",
      "priority": 12
    },
    {
      "ruleName": "LockoutRuleB5",
      "classGroupName": "B5",
      "formula": "if(BEGIN_BALANCE('B5,B6') / bal_at_issuance < VAR('SubLockoutPct') && BALANCE('B4') > 0) LOCKOUT()",
      "priority": 13
    },
    {
      "ruleName": "LockoutRuleB6",
      "classGroupName": "B6",
      "formula": "if(BEGIN_BALANCE('B6') / bal_at_issuance < VAR('SubLockoutPct') && BALANCE('B5') > 0) LOCKOUT()",
      "priority": 14
    },
    {
      "ruleName": "LockoutRuleSUB",
      "classGroupName": "SUB",
      "formula": "if(FAILED('MinCeTestA,MinCeTestB') && BALANCE('SSUP') > 0) LOCKOUT()",
      "priority": 15
    },
    {
      "ruleName": "DefaultSUBLockoutB1",
      "classGroupName": "B1",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B1')) LOCKOUT()",
      "priority": 16
    },
    {
      "ruleName": "DefaultSUBLockoutB2",
      "classGroupName": "B2",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B2')) LOCKOUT()",
      "priority": 17
    },
    {
      "ruleName": "DefaultSUBLockoutB3",
      "classGroupName": "B3",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B3')) LOCKOUT()",
      "priority": 18
    },
    {
      "ruleName": "DefaultSUBLockoutB4",
      "classGroupName": "B4",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B4')) LOCKOUT()",
      "priority": 19
    },
    {
      "ruleName": "DefaultSUBLockoutB5",
      "classGroupName": "B5",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B5')) LOCKOUT()",
      "priority": 20
    },
    {
      "ruleName": "DefaultSUBLockoutB6",
      "classGroupName": "B6",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B6')) LOCKOUT()",
      "priority": 21
    },
    {
      "ruleName": "Accrual1A9_1A8",
      "classGroupName": "1A9",
      "formula": "SET_ACCRETION('1A8')",
      "priority": 22
    },
    {
      "ruleName": "FailedCSDepletion",
      "classGroupName": "1A9",
      "formula": "if (FAILED('CredSuppDepletion')) SET_PAYMENT_PHASE()",
      "priority": 23
    },
    {
      "ruleName": "SetShiftPrinSched",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('StepDownTest')) SET_VAR('ShiftInterestSched', VAR('ShiftingInterestSchedule'))",
      "priority": 24
    },
    {
      "ruleName": "ShiftPct",
      "classGroupName": "GROUP_1",
      "formula": "if(PASSED('MinCeTestA,MinCeTestB_Sticky')) SET_VAR('ShiftPct', BEGIN_CLASS_PCT('SSEN,SSUP') + VAR('ShiftInterestSched') * (1 - BEGIN_CLASS_PCT('SSEN,SSUP'))); else SET_VAR('ShiftPct', 1);",
      "priority": 25
    },
    {
      "ruleName": "ShiftPct_NAS",
      "classGroupName": "GROUP_1",
      "formula": "SET_VAR('ShiftPctNAS', 1 - (1 - VAR('ShiftingInterestSchedule')) * BEGIN_BALANCE('SSUP') / BEGIN_BALANCE('SSEN,SSUP'))",
      "priority": 26
    },
    {
      "ruleName": "RecoveryShiftiPct",
      "classGroupName": "GROUP_1",
      "formula": "SET_VAR('RecovShiftPct', MIN(1, VAR('ShiftPct') * dp / rp))",
      "priority": 27
    }
