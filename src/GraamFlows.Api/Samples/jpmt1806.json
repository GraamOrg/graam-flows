      "priority": 5
    },
    {
      "ruleName": "ScheProRataFailed_G1",
      "classGroupName": "GROUP_1",
      "formula": "if (FAILED('CredSuppDepletion')) SET_SCHED_STRUCT( PRORATA(PRORATA( PRORATA('1A4,1A5,1A8,1A9'), PRORATA('1A10')), PRORATA('SUB' )))",
      "priority": 6
    },
    {
      "ruleName": "PpayShiftiFailed_G1",
      "classGroupName": "GROUP_1",
      "formula": "if (FAILED('CredSuppDepletion')) SET_PREPAY_STRUCT( SHIFTI('ShiftPct', SHIFTI('ShiftPctNAS', PRORATA('1A4,1A5,1A8,1A9'), PRORATA('1A10')), PRORATA('SUB' )))",
      "priority": 7
    },
    {
      "ruleName": "RecovShiftiFailed_G1",
