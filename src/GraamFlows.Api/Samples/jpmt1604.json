  "triggers": [
    {
      "triggerName": "MinCeTestA",
      "triggerType": "FORMULA_CONDITION",
      "triggerFormula": "BALANCE('SUB') / bal_at_issuance > .02 || BALANCE('SSEN,SSUP') < 1",
      "isMandatory": false,
      "groupNum": "1"
    },
    {
      "triggerName": "MinCeTestB",
      "triggerType": "FORMULA_CONDITION",
      "triggerFormula": "BEGIN_CLASS_PCT('SUB') > .0675 || BALANCE('SSEN,SSUP') < 1",
      "isMandatory": false,
      "groupNum": "1"
    },
    {
      "triggerName": "MinCeTestB_Sticky",
      "triggerType": "FORMULA_CONDITION_STICKY",
      "triggerFormula": "BEGIN_CLASS_PCT('SUB') > .0675 || BALANCE('SSEN,SSUP') < 1",
      "isMandatory": false,
      "groupNum": "1"
    },
    {
      "triggerName": "CredSuppDepletion",
      "triggerType": "FORMULA_CONDITION",
      "triggerFormula": "BALANCE('SUB') > .01",
      "isMandatory": false,
      "groupNum": "1"
    },
    {
      "triggerName": "StepDownTest",
      "triggerType": "FORMULA_CONDITION",
      "triggerFormula": "ccl / VAR('origSubBal') < VAR('StepDownTest')",
      "isMandatory": false,
      "groupNum": "1"
    },
    {
      "triggerName": "CleanUp",
      "triggerType": "COLLATERAL_VALUE",
      "triggerParam": "10",
      "isMandatory": false,
      "possibleValues": "Y,N,*",
      "groupNum": "1"
    }
  ],
  "payRules": [
    {
      "ruleName": "ScheProRata",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('CredSuppDepletion')) SET_SCHED_STRUCT( PRORATA(PRORATA( SEQ('A6,A10,A12'), PRORATA('SSUP')), PRORATA('SUB' )))",
      "priority": 0
    },
    {
      "ruleName": "PpayShifti",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('CredSuppDepletion')) SET_PREPAY_STRUCT( SHIFTI('ShiftPct', PRORATA(SEQ('A6,A10,A12'), PRORATA('SSUP')), PRORATA('SUB' )))",
      "priority": 1
    },
    {
      "ruleName": "RecovShifti",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('CredSuppDepletion')) SET_RECOV_STRUCT( SHIFTI('RecovShiftPct', PRORATA( SEQ('A6,A10,A12'), PRORATA('SSUP')), PRORATA('SUB' )))",
      "priority": 2
    },
    {
      "ruleName": "ScheProRataFailed",
      "classGroupName": "GROUP_1",
      "formula": "if (FAILED('CredSuppDepletion')) SET_SCHED_STRUCT( PRORATA(PRORATA( PRORATA('A6,A10,A12'), PRORATA('SSUP')), PRORATA('SUB' )))",
      "priority": 3
    },
    {
      "ruleName": "PpayShiftiFailed",
      "classGroupName": "GROUP_1",
      "formula": "if (FAILED('CredSuppDepletion')) SET_PREPAY_STRUCT( SHIFTI('ShiftPct', PRORATA(PRORATA('A6,A10,A12'), PRORATA('SSUP')), PRORATA('SUB' )))",
      "priority": 4
    },
    {
      "ruleName": "RecovShiftiFailed",
      "classGroupName": "GROUP_1",
      "formula": "if (FAILED('CredSuppDepletion')) SET_RECOV_STRUCT( SHIFTI('RecovShiftPct', PRORATA( PRORATA('A6,A10,A12'), PRORATA('SSUP')), PRORATA('SUB' )))",
      "priority": 5
    },
    {
      "ruleName": "LockoutRuleB1",
      "classGroupName": "B1",
      "formula": "if(BEGIN_BALANCE('B1,B2,B3,B4,B5') <= VAR('SubLockoutBal') && BALANCE('SSUP') > 0) LOCKOUT()",
      "priority": 6
    },
    {
      "ruleName": "LockoutRuleB2",
      "classGroupName": "B2",
      "formula": "if(BEGIN_BALANCE('B2,B3,B4,B5') <= VAR('SubLockoutBal') && BALANCE('B1') > 0) LOCKOUT()",
      "priority": 7
    },
    {
      "ruleName": "LockoutRuleB3",
      "classGroupName": "B3",
      "formula": "if(BEGIN_BALANCE('B3,B4,B5') <= VAR('SubLockoutBal') && BALANCE('B2') > 0) LOCKOUT()",
      "priority": 8
    },
    {
      "ruleName": "LockoutRuleB4",
      "classGroupName": "B4",
      "formula": "if(BEGIN_BALANCE('B4,B5') <= VAR('SubLockoutBal') && BALANCE('B3') > 0) LOCKOUT()",
      "priority": 9
    },
    {
      "ruleName": "LockoutRuleB5",
      "classGroupName": "B5",
      "formula": "if(BEGIN_BALANCE('B5') <= VAR('SubLockoutBal') && BALANCE('B4') > 0) LOCKOUT()",
      "priority": 10
    },
    {
      "ruleName": "LockoutA14",
      "classGroupName": "A14",
      "formula": "if(BALANCE('SSEN') > 0 && BEGIN_BALANCE('B4,B5') <= .01) LOCKOUT()",
      "priority": 11
    },
    {
      "ruleName": "LockoutRuleSUB",
      "classGroupName": "SUB",
      "formula": "if(FAILED('MinCeTestA,MinCeTestB') && BALANCE('SSUP') > 0) LOCKOUT()",
      "priority": 12
    },
    {
      "ruleName": "DefaultSUBLockoutB1",
      "classGroupName": "B1",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B1')) LOCKOUT()",
      "priority": 13
    },
    {
      "ruleName": "DefaultSUBLockoutB2",
      "classGroupName": "B2",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B2')) LOCKOUT()",
      "priority": 14
    },
    {
      "ruleName": "DefaultSUBLockoutB3",
      "classGroupName": "B3",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B3')) LOCKOUT()",
      "priority": 15
    },
    {
      "ruleName": "DefaultSUBLockoutB4",
      "classGroupName": "B4",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B4')) LOCKOUT()",
      "priority": 16
    },
    {
      "ruleName": "DefaultSUBLockoutB5",
      "classGroupName": "B5",
      "formula": "if (BEGIN_DETACH_POINT() < VAR('origCreditSupport_B5')) LOCKOUT()",
      "priority": 17
    },
    {
      "ruleName": "AccrualA10_A12",
      "classGroupName": "A12",
      "formula": "SET_ACCRETION('A10')",
      "priority": 18
    },
    {
      "ruleName": "SetShiftPrinSched",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('StepDownTest')) SET_VAR('ShiftInterestSched', VAR('ShiftingInterestSchedule'))",
      "priority": 19
    },
    {
      "ruleName": "ShiftPct",
      "classGroupName": "GROUP_1",
      "formula": "if(PASSED('MinCeTestA,MinCeTestB_Sticky')) SET_VAR('ShiftPct', BEGIN_CLASS_PCT('SSEN,SSUP') + VAR('ShiftInterestSched') * (1 - BEGIN_CLASS_PCT('SSEN,SSUP'))); else SET_VAR('ShiftPct', 1);",
      "priority": 20
    },
    {
      "ruleName": "RecoveryShiftiPct",
      "classGroupName": "GROUP_1",
      "formula": "SET_VAR('RecovShiftPct', MIN(1, VAR('ShiftPct') * dp / rp))",
      "priority": 21
    }
  ],
