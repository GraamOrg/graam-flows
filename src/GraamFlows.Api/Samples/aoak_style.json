    }
  ],
  "payRules": [
    {
      "ruleName": "SchedPrinPass",
      "classGroupName": "GROUP_1",
      "formula": "if (PASSED('CumNetLossTest,DelinquencyTest')) SET_SCHED_STRUCT(SEQ(PRORATA('A1','A2'), SINGLE('M1'), SINGLE('B1')))",
      "priority": 0
    },
    {
      "ruleName": "SchedPrinFail",
      "classGroupName": "GROUP_1",
      "formula": "if (FAILED('CumNetLossTest,DelinquencyTest')) SET_SCHED_STRUCT(SEQ(SINGLE('A1'), SINGLE('A2'), SINGLE('M1'), SINGLE('B1')))",
      "priority": 1
    },
    {
      "ruleName": "PrepayStruct",
      "classGroupName": "GROUP_1",
      "formula": "SET_PREPAY_STRUCT(SEQ(PRORATA('A1','A2'), SINGLE('M1'), SINGLE('B1')))",
      "priority": 2
    },
    {
      "ruleName": "RecovStruct",
      "classGroupName": "GROUP_1",
      "formula": "SET_RECOV_STRUCT(SEQ(PRORATA('A1','A2'), SINGLE('M1'), SINGLE('B1')))",
